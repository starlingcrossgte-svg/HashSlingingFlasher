<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/appTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HashSlingingFlasher"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/usbStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USB Status Unknown"
            android:textSize="22sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:padding="16dp" />

        <LinearLayout
            android:id="@+id/developerModePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#EEEEEE"
            android:padding="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/developerModeStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Developer Mode: OFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/toggleDeveloperModeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TOGGLE DEVELOPER MODE" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/developerToolsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/developerToolsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Developer Tools"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/developerLogText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Developer tools active"
                android:textSize="14sp"
                android:textColor="#333333"
                android:background="#FFFFFF"
                android:padding="12dp" />
        </LinearLayout>

        <Button
            android:id="@+id/refreshButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REFRESH USB STATUS"
            android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>
