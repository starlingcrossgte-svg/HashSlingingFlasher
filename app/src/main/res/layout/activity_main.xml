<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header -->
    <TextView
        android:id="@+id/header_title"
        android:text="HashSlingingFlasher"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Toggle Developer Mode -->
    <Button
        android:id="@+id/button_toggle_dev"
        android:text="TOGGLE DEVELOPER MODE"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"/>

    <!-- Overall Status -->
    <TextView
        android:id="@+id/text_overall_status"
        android:text="USB Status Unknown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"/>

    <!-- Manual Command Console -->
    <EditText
        android:id="@+id/edit_manual_command"
        android:hint="Enter OpenPort command, example: ati\r\n"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/button_send_command"
        android:text="SEND MANUAL COMMAND"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/button_refresh_usb"
        android:text="REFRESH USB STATUS"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"/>

</LinearLayout>
